# Application Config
APP_NAME="CyberSathi Backend"
APP_ENV="local"
DEBUG=true
API_V1_STR="/api/v1"
PROJECT_NAME="CyberSathi"

# Server Config
HOST="0.0.0.0"
PORT=8000

# Logging
LOG_LEVEL="INFO"

# Phishing Classifier Settings
CLASSIFIER_MODEL_NAME="CrabInHoney/urlbert-tiny-v4-phishing-classifier"
CLASSIFIER_THRESHOLD=0.75

# Deep Website Inspection Settings
PLAYWRIGHT_TIMEOUT_MS=15000
PLAYWRIGHT_HEADLESS=true
HTTP_REQUEST_TIMEOUT_SEC=10
MAX_DNS_LOOKUP_RETRY=3

# LLM Reasoning Config
LLM_PROVIDER="openai" # openai, anthropic, or local
LLM_API_KEY="your_api_key_here"
LLM_MODEL="gpt-4o"
LLM_TEMPERATURE=0.0

# CORS Configuration
BACKEND_CORS_ORIGINS="http://localhost:3000,http://localhost:8000"

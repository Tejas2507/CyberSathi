# ═══════════════════════════════════════════════════════════════
# CyberSathi — Environment Variables Reference
# Copy this file to .env and fill in your actual values.
# NEVER commit .env to version control.
# ═══════════════════════════════════════════════════════════════

# ── Application ──────────────────────────────────────────────
APP_NAME="CyberSathi Backend"
APP_ENV="local"           # local | staging | production
DEBUG=true
API_V1_STR="/api/v1"
PROJECT_NAME="CyberSathi"

# ── Server ───────────────────────────────────────────────────
HOST="0.0.0.0"
PORT=8000

# ── Logging ──────────────────────────────────────────────────
LOG_LEVEL="INFO"          # DEBUG | INFO | WARNING | ERROR | CRITICAL

# ── ML Phishing URL Classifier ────────────────────────────────
CLASSIFIER_MODEL_NAME="CrabInHoney/urlbert-tiny-v4-phishing-classifier"
CLASSIFIER_THRESHOLD=0.75

# ── Browser / Playwright ─────────────────────────────────────
PLAYWRIGHT_TIMEOUT_MS=15000
PLAYWRIGHT_HEADLESS=true
HTTP_REQUEST_TIMEOUT_SEC=10
MAX_DNS_LOOKUP_RETRY=3

# ── Gemini LLM ───────────────────────────────────────────────
# Get your API key from: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=""
GEMINI_MODEL="gemini-2.0-flash"   # Recommended: gemini-2.0-flash | gemini-2.5-flash
LLM_TEMPERATURE=0.0

# ── Confirmed Phishing SQLite Database ───────────────────────
PHISHING_DB_PATH="confirmed_phishing.db"
PHISHING_CONFIDENCE_THRESHOLD=0.95   # Only cache verdicts with confidence >= this

# ── CORS ─────────────────────────────────────────────────────
BACKEND_CORS_ORIGINS="http://localhost:3000,http://localhost:8000"
